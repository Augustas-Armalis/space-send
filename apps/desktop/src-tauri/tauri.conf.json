{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Space Send",
  "version": "0.1.0",
  "identifier": "com.contles.spacesend",
  "build": {
    "frontendDist": "../../../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm --prefix ../../.. run dev",
    "beforeBuildCommand": "npm --prefix ../../.. run build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Space Send",
        "width": 1120,
        "height": 760,
        "minWidth": 380,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "backgroundColor": "#04040a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": ["icons/icon.icns", "icons/icon.png"],
    "category": "Productivity",
    "shortDescription": "Transmit anything. Instantly.",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-",
      "entitlements": null
    }
  }
}
