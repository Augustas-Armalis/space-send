# Space Send — environment variables (all optional for the local demo).
# Copy to .env.local and fill in to enable cross-device features.

# --- Cross-device Beams (WebRTC signaling) ---
# Deploy packages/signaling-worker, then point here. Without it, the app uses
# BroadcastChannel signaling (local same-machine two-tab demo only).
# NEXT_PUBLIC_SIGNAL_URL=wss://space-send-signaling.<account>.workers.dev

# --- TURN relay (for peers behind strict NATs). STUN is built in. ---
# NEXT_PUBLIC_TURN_URL=turn:relay.example.com:3478
# NEXT_PUBLIC_TURN_USER=
# NEXT_PUBLIC_TURN_CRED=

# --- Managed cloud storage (Drop across devices) — swap the IndexedDB backend ---
# Server-side only; mint presigned PUT/GET URLs. Never expose secrets to the client.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=space-send

# --- Stripe metered billing (pay-as-you-go overage) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
